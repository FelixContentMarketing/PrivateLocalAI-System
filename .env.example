# =============================================================
# Kanzlei Kissling KI-Assistent -- Umgebungsvariablen
# =============================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# =============================================================

# --- PFLICHT ---

# JWT Secret (generieren mit: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Admin-Benutzer (wird beim Start automatisch angelegt)
ADMIN_EMAIL=admin@kanzlei-kissling.de
ADMIN_PASSWORD=sicheres-passwort-hier

# --- OPTIONAL ---

# Datenbank: PostgreSQL (Cloud/Coolify) oder leer fuer SQLite (lokal)
# Fuer lokale Docker-Installation mit PostgreSQL:
#   docker compose --profile postgres up -d
#   DATABASE_URL=postgresql://kissling:kissling@postgres:5432/kissling
# Fuer Coolify: PostgreSQL als Coolify-Service anlegen und URL hier eintragen
DATABASE_URL=

# PostgreSQL-Passwort (nur fuer lokale Docker-Installation mit PostgreSQL-Profil)
POSTGRES_PASSWORD=kissling

# OpenRouter API Key (fuer Cloud-Modelle)
# Beziehbar unter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Standard Cloud-Modell
SELECTED_MODEL=google/gemini-2.5-flash

# Ollama URL (Lokal-Modus)
# Lokal:              http://localhost:11434
# Docker Desktop:     http://host.docker.internal:11434
# Docker Linux:       http://172.17.0.1:11434
OLLAMA_BASE_URL=http://localhost:11434

# Server-Port
PORT=8000

# CORS Origins (kommasepariert, leer = nur Same-Origin)
CORS_ORIGINS=
